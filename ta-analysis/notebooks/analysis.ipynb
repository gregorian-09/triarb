# # Triangular Arbitrage Backtest Analysis
#
# Load results from the Rust simulator and compute performance metrics.

# %%
from pathlib import Path

import pandas as pd
import plotly.io as pio

from ta_analysis.config import AnalysisConfig, BacktestConfig
from ta_analysis.loader import load_jsonl_df
from ta_analysis.metrics import (
    compute_equity_curve,
    compute_drawdown,
    compute_sharpe,
    compute_summary,
)
from ta_analysis.visualize import (
    plot_equity_curve,
    plot_trade_scatter,
    plot_opportunity_distribution,
)

pio.renderers.default = "notebook"

# %%
config = BacktestConfig(
    analysis=AnalysisConfig(
        data_path="backtest_results.jsonl",
        initial_capital=10_000.0,
        trade_size_usdt=100.0,
    )
)
print(config)

# %%
df = load_jsonl_df(config.analysis.data_path)
print(f"Loaded {len(df)} events")
df.head()

# %%
summary = compute_summary(
    df,
    initial_capital=config.analysis.initial_capital,
    trade_size_usdt=config.analysis.trade_size_usdt,
)
print(summary)

# %%
fig1 = plot_equity_curve(
    df,
    initial_capital=config.analysis.initial_capital,
    trade_size_usdt=config.analysis.trade_size_usdt,
)
fig1.show()

# %%
fig2 = plot_trade_scatter(df)
fig2.show()

# %%
fig3 = plot_opportunity_distribution(df)
fig3.show()

