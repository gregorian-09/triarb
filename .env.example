# Triangular Arbitrage Bot – Local Development
# Copy to .env and fill in your exchange API keys.
# Use read-only keys for market data; use separate keys for trading.
# chmod 600 .env

# Binance (primary exchange)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# OKX (secondary)
# OKX_API_KEY=
# OKX_SECRET_KEY=

# Bybit (secondary)
# BYBIT_API_KEY=
# BYBIT_SECRET_KEY=
